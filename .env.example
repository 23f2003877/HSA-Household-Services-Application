# .env.example — A-Z Household Services
# Copy to .env and fill in your values

# Flask
SECRET_KEY=change_this_secret_key_in_production_use_32+_chars
FLASK_DEBUG=1
PORT=5000

# JWT
JWT_SECRET_KEY=change_this_jwt_key_in_production_use_32+_chars
JWT_EXPIRES_SECONDS=3600

# Database
DATABASE_URL=sqlite:///backend/hsa.db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Admin (seeded on first run)
ADMIN_EMAIL=admin@hsa.com
ADMIN_PASSWORD=admin123
